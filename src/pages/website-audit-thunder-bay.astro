---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Website audit Thunder Bay | ThunderBayAI" description="Website audit for Thunder Bay businesses that need stronger local visibility, clearer conversion paths, and better lead capture.">
  <section class="section">
    <div class="container split-panel">
      <div class="section-heading">
        <p class="eyebrow">Conversion page</p>
        <h1>Request a website audit for your Thunder Bay business.</h1>
        <p class="lead">If your site is outdated, hard to navigate, weak on search intent, or not turning traffic into conversations, the fastest next step is a practical audit. Fixing the website often improves both SEO and conversion at the same time.</p>
        <div class="hero-actions">
          <a class="button" href="https://frayze.ca/contact/">Request Website Audit</a>
          <a class="button secondary" href="/thunder-bay-local-seo">See local SEO pathway</a>
        </div>
      </div>
      <div class="card">
        <p class="eyebrow">What gets reviewed</p>
        <ul class="check-list">
          <li>headline and offer clarity</li>
          <li>local service-page coverage</li>
          <li>CTA structure and form quality</li>
          <li>trust signals and internal linking</li>
          <li>page speed, intent match, and crawl basics</li>
        </ul>
      </div>
    </div>
  </section>
  <section class="section" style="padding-top:0;">
    <div class="container card">
      <h2>Related pathways</h2>
      <div class="kicker-bar">
        <a class="kicker-chip" href="/thunder-bay-website-systems">Website systems</a>
        <a class="kicker-chip" href="/thunder-bay-local-seo">Local SEO</a>
        <a class="kicker-chip" href="/thunder-bay-lead-generation-systems">Lead generation systems</a>
        <a class="kicker-chip" href="/services">Services hub</a>
      </div>
    </div>
  </section>
</BaseLayout>
