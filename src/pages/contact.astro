---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact | ThunderBayAI" description="Contact pathway for Thunder Bay businesses that want an audit, strategy call, workflow map, or implementation support through Frayze.">
  <section class="section">
    <div class="container grid grid-2">
      <div class="card">
        <p class="eyebrow">Contact</p>
        <h1>Need help deciding what to fix first?</h1>
        <p class="muted">If you already know your business needs better systems, stronger follow-up, cleaner website conversion, or improved local visibility, the next move is a conversation.</p>
        <div class="hero-actions">
          <a class="button" href="https://frayze.ca/contact/">Contact Frayze</a>
          <a class="button secondary" href="https://frayze.ca/book-consultation/">Book Strategy Call</a>
        </div>
      </div>
      <div class="card">
        <h2>Common starting points</h2>
        <ul class="check-list">
          <li><a href="/ai-opportunity-audit">AI Opportunity Audit</a></li>
          <li><a href="/website-audit-thunder-bay">Website Audit</a></li>
          <li><a href="/workflow-map">Workflow Map</a></li>
          <li><a href="/services">Services Hub</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
