---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Thunder Bay website systems | ThunderBayAI" description="Website systems for Thunder Bay businesses that need more than a brochure site: lead capture, conversion flow, and growth infrastructure.">
  <section class="section">
    <div class="container section-heading">
      <p class="eyebrow">Primary keyword: Thunder Bay website systems</p>
      <h1>Thunder Bay website systems built to capture leads, qualify demand, and support growth.</h1>
      <p class="lead">A modern website should act like a system, not a placeholder. It should support search visibility, trust, conversion, CTA routing, and clean handoff into follow-up.</p>
      <div class="hero-actions">
        <a class="button" href="https://frayze.ca/website-launch-program/">See Website & CRM Core</a>
        <a class="button secondary" href="/website-audit-thunder-bay">Request Website Audit</a>
      </div>
    </div>
  </section>
  <section class="section" style="padding-top:0;">
    <div class="container grid grid-2">
      <div class="card">
        <h2>What a stronger website system includes</h2>
        <ul class="check-list">
          <li>clear local positioning and offers</li>
          <li>CTA paths for audits, calls, and workflow requests</li>
          <li>service pages aligned to search intent</li>
          <li>forms and events connected to CRM and follow-up</li>
          <li>content that supports both rankings and conversion</li>
        </ul>
      </div>
      <div class="card">
        <h2>Related pathways</h2>
        <div class="kicker-bar">
          <a class="kicker-chip" href="/thunder-bay-local-seo">Thunder Bay local SEO</a>
          <a class="kicker-chip" href="/thunder-bay-crm-systems">Thunder Bay CRM systems</a>
          <a class="kicker-chip" href="/thunder-bay-lead-generation-systems">Lead generation systems</a>
          <a class="kicker-chip" href="/ai-opportunity-audit">AI opportunity audit</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
