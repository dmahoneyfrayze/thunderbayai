---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Automation opportunity scorecard | ThunderBayAI" description="A simple scorecard to estimate whether your Thunder Bay business is ready for automation, CRM improvement, or workflow mapping.">
  <section class="section">
    <div class="container split-panel">
      <div class="section-heading">
        <p class="eyebrow">Lead magnet tool</p>
        <h1>Automation opportunity scorecard.</h1>
        <p class="lead">Use this quick scorecard to estimate whether your business should prioritize AI automation, CRM cleanup, website conversion fixes, or a workflow map first.</p>
      </div>
      <div class="card">
        <form id="scorecard" class="grid" style="gap:1rem;">
          <label><span class="muted">Do leads come from multiple channels?</span><select id="q1" style="width:100%;margin-top:.35rem;padding:.9rem 1rem;border-radius:14px;border:1px solid var(--line);background:#0c1724;color:var(--text);"><option value="3">Yes, many</option><option value="2">A few</option><option value="0">No</option></select></label>
          <label><span class="muted">Is follow-up inconsistent?</span><select id="q2" style="width:100%;margin-top:.35rem;padding:.9rem 1rem;border-radius:14px;border:1px solid var(--line);background:#0c1724;color:var(--text);"><option value="3">Often</option><option value="2">Sometimes</option><option value="0">Rarely</option></select></label>
          <label><span class="muted">Does admin work slow staff down?</span><select id="q3" style="width:100%;margin-top:.35rem;padding:.9rem 1rem;border-radius:14px;border:1px solid var(--line);background:#0c1724;color:var(--text);"><option value="3">Yes</option><option value="2">Somewhat</option><option value="0">No</option></select></label>
          <label><span class="muted">Is your website a strong conversion asset?</span><select id="q4" style="width:100%;margin-top:.35rem;padding:.9rem 1rem;border-radius:14px;border:1px solid var(--line);background:#0c1724;color:var(--text);"><option value="3">No</option><option value="1">Maybe</option><option value="0">Yes</option></select></label>
          <button class="button" type="submit" style="border:none;cursor:pointer;">Calculate score</button>
        </form>
      </div>
    </div>
  </section>
  <section class="section" style="padding-top:0;">
    <div class="container grid grid-2">
      <div class="card"><p class="eyebrow">Score</p><h2 id="scoreValue">11 / 12</h2><p class="muted" id="scoreText">High automation opportunity. Start with an audit and workflow map.</p></div>
      <div class="card"><h2>Suggested next move</h2><div class="kicker-bar"><a class="kicker-chip" href="/ai-opportunity-audit">AI opportunity audit</a><a class="kicker-chip" href="/workflow-map">Workflow map</a><a class="kicker-chip" href="/thunder-bay-crm-systems">CRM systems</a><a class="kicker-chip" href="/website-audit-thunder-bay">Website audit</a></div></div>
    </div>
  </section>
  <script is:inline>
    const form = document.getElementById('scorecard');
    const scoreValue = document.getElementById('scoreValue');
    const scoreText = document.getElementById('scoreText');
    const updateScore = () => {
      const total = ['q1','q2','q3','q4'].reduce((sum, id) => sum + Number(document.getElementById(id).value || 0), 0);
      scoreValue.textContent = `${total} / 12`;
      if (total >= 9) scoreText.textContent = 'High automation opportunity. Start with an audit and workflow map.';
      else if (total >= 5) scoreText.textContent = 'Moderate opportunity. Tighten systems and prioritize the most painful bottleneck first.';
      else scoreText.textContent = 'Lower urgency. Focus on foundational visibility or conversion improvements first.';
    };
    form?.addEventListener('submit', (e) => { e.preventDefault(); updateScore(); });
    updateScore();
  </script>
</BaseLayout>
