---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Free AI audit | ThunderBayAI" description="Request a free AI opportunity audit to identify automation, CRM, website, and lead-system opportunities for your Thunder Bay business.">
  <section class="section">
    <div class="container split-panel">
      <div class="section-heading">
        <p class="eyebrow">Primary CTA</p>
        <h1>Get a free AI opportunity audit.</h1>
        <p class="lead">This is the fastest path if you want a practical view of where AI, automation, CRM, or website upgrades could improve lead flow and operations.</p>
        <div class="hero-actions">
          <a class="button" href="https://frayze.ca/resources/automation-readiness-roi/">Get the Free AI Audit</a>
          <a class="button secondary" href="/services">Explore service pathways</a>
        </div>
      </div>
      <div class="card">
        <p class="eyebrow">Typical audit outputs</p>
        <ul class="check-list">
          <li>where leads are leaking</li>
          <li>what to automate first</li>
          <li>whether the website is helping or hurting conversion</li>
          <li>which systems should connect next</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
