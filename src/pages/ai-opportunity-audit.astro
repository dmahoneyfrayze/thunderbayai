---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="AI opportunity audit for Thunder Bay businesses | ThunderBayAI" description="Free AI opportunity audit for Thunder Bay and Northwestern Ontario businesses to identify automation, CRM, website, and lead-generation opportunities.">
  <section class="section">
    <div class="container split-panel">
      <div class="section-heading">
        <p class="eyebrow">Lead magnet</p>
        <h1>Get a free AI opportunity audit for your Thunder Bay business.</h1>
        <p class="lead">If you are trying to figure out where AI can actually save time, reduce missed leads, or improve follow-up, start with an audit. The goal is not to push tools. It is to identify the highest-value moves first.</p>
        <div class="hero-actions">
          <a class="button" href="https://frayze.ca/resources/automation-readiness-roi/">Get the Free AI Audit</a>
          <a class="button secondary" href="/services">Explore service pathways</a>
        </div>
      </div>
      <div class="card">
        <p class="eyebrow">What the audit looks at</p>
        <ul class="check-list">
          <li>lead response speed</li>
          <li>missed follow-up and dropped opportunities</li>
          <li>manual admin that should be automated</li>
          <li>website conversion gaps</li>
          <li>CRM and workflow bottlenecks</li>
        </ul>
      </div>
    </div>
  </section>
  <section class="section" style="padding-top:0;">
    <div class="container grid grid-2">
      <div class="card">
        <h2>Best fit</h2>
        <p class="muted">Businesses with real lead flow, recurring inbound demand, obvious admin drag, weak follow-up, or outdated digital systems.</p>
      </div>
      <div class="card">
        <h2>Related pages</h2>
        <div class="kicker-bar">
          <a class="kicker-chip" href="/thunder-bay-ai-automation">AI automation</a>
          <a class="kicker-chip" href="/thunder-bay-crm-systems">CRM systems</a>
          <a class="kicker-chip" href="/website-audit-thunder-bay">Website audit</a>
          <a class="kicker-chip" href="/thunder-bay-local-seo">Local SEO</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
