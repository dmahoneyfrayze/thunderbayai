---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---
<BaseLayout title="AI for real-estate | ThunderBayAI">
  <section class="section">
    <div class="container grid" style="gap:1.5rem;">
      <p class="eyebrow">Industry hub</p>
      <h1 style="margin:0;text-transform:capitalize;">AI for real-estate</h1>
      <div class="card">
        <p>This hub is scaffolded for final vertical copy: workflow problems, local opportunities, featured articles, and Frayze CTA routing.</p>
      </div>
      <CTASection title="Request a Local Workflow Map" body="If response time, follow-up, booking flow, or admin drag is hurting growth, start with the workflow map." buttonText="Request the Workflow Map" href="https://frayze.ca/contact/" />
    </div>
  </section>
</BaseLayout>
