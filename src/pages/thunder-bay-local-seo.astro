---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Thunder Bay local SEO | ThunderBayAI" description="Local SEO for Thunder Bay businesses that need better visibility, stronger conversion pages, and more qualified search traffic.">
  <section class="section">
    <div class="container split-panel">
      <div class="section-heading">
        <p class="eyebrow">Primary keyword: Thunder Bay local SEO</p>
        <h1>Thunder Bay local SEO for businesses that should be showing up more often when buyers are ready.</h1>
        <p class="lead">Local SEO is not just rankings. It is visibility plus conversion. The win comes when the right business appears in search, the page matches intent, and the site gives buyers a clean next step.</p>
        <div class="hero-actions">
          <a class="button" href="https://frayze.ca/solutions/web-design-local-seo/">See Frayze SEO</a>
          <a class="button secondary" href="/website-audit-thunder-bay">Request Website Audit</a>
        </div>
      </div>
      <div class="card">
        <p class="eyebrow">Where local SEO breaks</p>
        <ul class="check-list">
          <li>service pages are thin or missing entirely</li>
          <li>the site does not target local commercial intent</li>
          <li>metadata and internal links are weak</li>
          <li>traffic lands on pages that do not convert</li>
        </ul>
      </div>
    </div>
  </section>
  <section class="section" style="padding-top:0;">
    <div class="container grid grid-2">
      <div class="card">
        <h2>Priority local SEO assets</h2>
        <ul class="check-list">
          <li>city + service landing pages</li>
          <li>industry pages with local modifiers</li>
          <li>FAQ clusters tied to buying intent</li>
          <li>internal links from educational pages into money pages</li>
          <li>schema, metadata, and clear conversion CTAs</li>
        </ul>
      </div>
      <div class="card">
        <h2>Related pathways</h2>
        <div class="kicker-bar">
          <a class="kicker-chip" href="/thunder-bay-website-systems">Website systems</a>
          <a class="kicker-chip" href="/thunder-bay-lead-generation-systems">Lead generation systems</a>
          <a class="kicker-chip" href="/website-audit-thunder-bay">Website audit</a>
          <a class="kicker-chip" href="/services">Services hub</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
