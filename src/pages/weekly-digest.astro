---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Weekly Digest | ThunderBayAI" description="Weekly digest of practical AI developments, local opportunities, and business-useful updates for Thunder Bay and Northwestern Ontario.">
  <section class="section">
    <div class="container split-panel">
      <div class="section-heading">
        <p class="eyebrow">Weekly Digest</p>
        <h1>A practical weekly digest for Thunder Bay and Northwestern Ontario businesses watching AI.</h1>
        <p class="lead">The digest translates AI changes into business consequences: what matters, who should care, and what local operators should do next.</p>
      </div>
      <div class="card">
        <p class="eyebrow">Why subscribe</p>
        <ul class="check-list">
          <li>local relevance, not generic AI hype</li>
          <li>practical business implications</li>
          <li>early visibility on tools and opportunities</li>
          <li>a direct path into audits and strategy calls when needed</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
