---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Restaurant marketing automation Thunder Bay | ThunderBayAI" description="Marketing automation for restaurants in Thunder Bay focused on reservations, repeat visits, customer messaging, and local visibility.">
  <section class="section">
    <div class="container split-panel">
      <div class="section-heading">
        <p class="eyebrow">Vertical page</p>
        <h1>Restaurant marketing automation in Thunder Bay for repeat visits, reservations, and faster customer response.</h1>
        <p class="lead">Restaurants do not need abstract AI. They need simpler ways to handle questions, reservations, promotions, reviews, and repeat-visit campaigns without more manual admin.</p>
        <div class="hero-actions">
          <a class="button" href="https://frayze.ca/book-consultation/">Book an AI Strategy Call</a>
          <a class="button secondary" href="/ai-opportunity-audit">Get a Free AI Opportunity Audit</a>
        </div>
      </div>
      <div class="card">
        <p class="eyebrow">Fastest wins</p>
        <ul class="check-list">
          <li>reservation and inquiry response workflows</li>
          <li>review request and reputation loops</li>
          <li>repeat-customer SMS and email campaigns</li>
          <li>specials, events, and seasonal offer reminders</li>
        </ul>
      </div>
    </div>
  </section>
  <section class="section" style="padding-top:0;">
    <div class="container card">
      <h2>Related pathways</h2>
      <div class="kicker-bar">
        <a class="kicker-chip" href="/thunder-bay-ai-automation">AI automation</a>
        <a class="kicker-chip" href="/thunder-bay-local-seo">Local SEO</a>
        <a class="kicker-chip" href="/thunder-bay-lead-generation-systems">Lead generation systems</a>
        <a class="kicker-chip" href="/ai-for-restaurants">AI for restaurants</a>
      </div>
    </div>
  </section>
</BaseLayout>
