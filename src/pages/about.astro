---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About ThunderBayAI | Local AI authority for Northwestern Ontario" description="About ThunderBayAI, the local AI authority and education engine for Thunder Bay and Northwestern Ontario businesses." ogImage="/images/generated/001-luxury-ai-product-website-artwork-for-a-.png">
  <section class="section">
    <div class="container split-panel">
      <div class="section-heading">
        <p class="eyebrow">About</p>
        <h1>ThunderBayAI exists to make AI, automation, and digital growth practical for local businesses.</h1>
        <p class="lead">ThunderBayAI is built as a local authority layer for Thunder Bay and Northwestern Ontario. Its role is to help owners and operators understand what matters, what is hype, what can be implemented now, and where the real commercial opportunities are.</p>
        <div class="hero-actions">
          <a class="button" href="/weekly-digest">Join the Weekly Digest</a>
          <a class="button secondary" href="/services">Explore service pathways</a>
        </div>
      </div>
      <div>
        <div class="showcase-frame">
          <img src="/images/generated/001-luxury-ai-product-website-artwork-for-a-.png" alt="Premium about-page visual with cinematic AI dashboards and luxury editorial styling." />
          <div class="showcase-badge">
            <p class="eyebrow">Why this exists</p>
            <p class="muted" style="margin:0;">To own local AI awareness in Northwestern Ontario, earn trust early, and route serious implementation demand into Frayze.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container grid grid-2">
      <div class="card">
        <p class="eyebrow">Positioning</p>
        <ul class="check-list">
          <li>ThunderBayAI = attention, education, and authority</li>
          <li>Frayze = implementation, systems, and monetization path</li>
          <li>Every page should help rank, convert, or build local trust</li>
        </ul>
      </div>
      <div class="card">
        <p class="eyebrow">Use cases</p>
        <ul class="check-list">
          <li>translate AI announcements into local business impact</li>
          <li>show business owners where automation fits</li>
          <li>surface tools, audits, and implementation paths</li>
          <li>become the regional source of truth for useful AI coverage</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
