---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contractor CRM automation Thunder Bay | ThunderBayAI" description="CRM automation for contractors in Thunder Bay looking to improve quote follow-up, missed-call recovery, pipeline visibility, and booking flow.">
  <section class="section">
    <div class="container split-panel">
      <div class="section-heading">
        <p class="eyebrow">Vertical page</p>
        <h1>Contractor CRM automation in Thunder Bay for faster follow-up and fewer lost jobs.</h1>
        <p class="lead">Contractors usually do not lose work because demand does not exist. They lose work because calls get missed, quotes stall, reminders fall apart, and the follow-up system depends on memory.</p>
        <div class="hero-actions">
          <a class="button" href="https://frayze.ca/contact/">Request a Local Workflow Map</a>
          <a class="button secondary" href="/ai-opportunity-audit">Get a Free AI Opportunity Audit</a>
        </div>
      </div>
      <div class="card">
        <p class="eyebrow">Top fixes</p>
        <ul class="check-list">
          <li>missed-call text back</li>
          <li>lead routing and tagging</li>
          <li>estimate reminder workflows</li>
          <li>quote follow-up sequences</li>
          <li>review and referral triggers after job completion</li>
        </ul>
      </div>
    </div>
  </section>
  <section class="section" style="padding-top:0;">
    <div class="container card">
      <h2>Related pathways</h2>
      <div class="kicker-bar">
        <a class="kicker-chip" href="/thunder-bay-ai-automation">AI automation</a>
        <a class="kicker-chip" href="/thunder-bay-crm-systems">CRM systems</a>
        <a class="kicker-chip" href="/ai-for-contractors">AI for contractors</a>
        <a class="kicker-chip" href="/thunder-bay-lead-generation-systems">Lead generation systems</a>
      </div>
    </div>
  </section>
</BaseLayout>
