---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Tools | ThunderBayAI" description="Lead tools, calculators, and scorecards for Thunder Bay and Northwestern Ontario businesses exploring AI, automation, websites, and growth systems." ogImage="/images/generated/002-luxury-ai-product-website-artwork-for-a-.png">
  <section class="section">
    <div class="container split-panel">
      <div class="section-heading">
        <p class="eyebrow">Tools</p>
        <h1>Interactive tools that turn curiosity into action.</h1>
        <p class="lead">ThunderBayAI should not just publish articles. It should give business owners useful ways to diagnose problems, estimate opportunity, and move into an audit or strategy conversation when the time is right.</p>
        <div class="hero-actions">
          <a class="button" href="/missed-lead-calculator">Try the Missed Lead Calculator</a>
          <a class="button secondary" href="/automation-opportunity-scorecard">Open the Scorecard</a>
        </div>
      </div>
      <div>
        <div class="showcase-frame">
          <img src="/images/generated/002-luxury-ai-product-website-artwork-for-a-.png" alt="Premium AI tools page visual with elegant dashboard interface and cinematic lighting." />
          <div class="showcase-badge">
            <p class="eyebrow">Premium tool UX</p>
            <p class="muted" style="margin:0;">These tools exist to create clarity fast, surface opportunity, and route serious users into the right next step.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="section" style="padding-top:0;">
    <div class="container grid grid-2">
      <a class="card card-link" href="/missed-lead-calculator"><p class="eyebrow">Calculator</p><h3>Missed Lead Calculator</h3><p class="muted">Estimate how much slow response and weak follow-up may be costing each month.</p></a>
      <a class="card card-link" href="/automation-opportunity-scorecard"><p class="eyebrow">Scorecard</p><h3>Automation Opportunity Scorecard</h3><p class="muted">See whether automation, CRM cleanup, or website conversion work should be prioritized first.</p></a>
      <a class="card card-link" href="/ai-opportunity-audit"><p class="eyebrow">Audit</p><h3>AI Opportunity Audit</h3><p class="muted">The main lead magnet for businesses ready to identify practical AI and workflow opportunities.</p></a>
      <a class="card card-link" href="/website-audit-thunder-bay"><p class="eyebrow">Audit</p><h3>Website Audit</h3><p class="muted">A conversion-focused audit pathway for businesses with outdated or underperforming sites.</p></a>
    </div>
  </section>
</BaseLayout>
